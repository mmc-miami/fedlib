    })

    local left_text = self:create("TextLabel", {
        Parent = slider_holder,
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular),
        TextColor3 = themes.preset.text,
        BorderColor3 = rgb(0, 0, 0),
        Text = cfg.name,
        BackgroundTransparency = 1,
        Size = dim2(0, 0, 1, -1),
        BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.X,
        TextSize = 12,
        BackgroundColor3 = rgb(255, 255, 255)
    })

    local slider_bar = self:create("TextButton", {
        Parent = slider_holder,
        Position = dim2(0, 0, 0, 15),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(1, 0, 0, 12),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline,
        Text = "",
        AutoButtonColor = false,
    })

    local slider_fill = self:create("Frame", {
        Parent = slider_bar,
        Position = dim2(0, 1, 0, 1),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2((cfg.default - cfg.min) / (cfg.max - cfg.min), 0, 1, -2),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.accent
    })

    local slider_value = self:create("TextLabel", {
        Parent = slider_fill,
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular),
        TextColor3 = themes.preset.text,
        BorderColor3 = rgb(0, 0, 0),
        Text = tostring(cfg.default),
        Size = dim2(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Position = dim2(0, 2, 0, -1),
        BorderSizePixel = 0,
        TextSize = 10,
        BackgroundColor3 = rgb(255, 255, 255)
    })

    local dragging = false

    function cfg.set(value)
        cfg.value = math.clamp(value, cfg.min, cfg.max)
        slider_fill.Size = dim2((cfg.value - cfg.min) / (cfg.max - cfg.min), 0, 1, -2)
        slider_value.Text = tostring(cfg.value)
        flags[cfg.flag] = cfg.value
        cfg.callback(flags[cfg.flag])
    end

    slider_bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    uis.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    uis.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local size_x = (input.Position.X - slider_bar.AbsolutePosition.X) / slider_bar.AbsoluteSize.X
            local value = ((cfg.max - cfg.min) * size_x) + cfg.min
            cfg.set(value)
        end
    end)

    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set

    return setmetatable(cfg, {__index = library})
end

