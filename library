function library:slider(options)
    options = options or {}
    local cfg = {
        name = options.name or "Slider",
        suffix = options.suffix or "",
        flag = options.flag or tostring(random(1, 9999999)),
        callback = options.callback or function() end,
        visible = options.visible or true,
        min = options.min or options.minimum or 0,
        max = options.max or options.maximum or 100,
        intervals = options.interval or options.decimal or 1,
        default = options.default or 10,
        dragging = false,
        value = options.default or 10,
    }

    flags[cfg.flag] = cfg.default

    local slider_frame = library:create("TextLabel", {
        Parent = self and self.holder or nil,
        Text = "",
        Name = "slider_" .. cfg.flag,
        Size = dim2(1, -8, 0, 12),
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutomaticSize = Enum.AutomaticSize.Y,
    })

    local label = library:create("TextLabel", {
        Parent = slider_frame,
        Text = cfg.name,
        TextColor3 = themes.preset.text,
        BackgroundTransparency = 1,
        BorderColor3 = rgb(0, 0, 0),
        Position = dim2(0, 2, 0, -1),
        Size = dim2(0.5, 0, 0, 14),
        BorderSizePixel = 0,
        TextSize = 10,
    })

    local value_label = library:create("TextLabel", {
        Parent = slider_frame,
        Text = tostring(cfg.default),
        TextColor3 = themes.preset.text,
        BackgroundTransparency = 1,
        BorderColor3 = rgb(0, 0, 0),
        Position = dim2(0.5, 0, 0, -1),
        Size = dim2(0.5, 0, 0, 14),
        BorderSizePixel = 0,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local slider_bg = library:create("TextButton", {
        Parent = slider_frame,
        Name = "slider",
        Position = dim2(0, 0, 0, 16),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(1, 0, 0, 12),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline,
        Text = "",
        AutoButtonColor = false,
    })

    local inline = library:create("Frame", {
        Parent = slider_bg,
        Position = dim2(0, 1, 0, 1),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(1, -2, 1, -2),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })

    local fill = library:create("Frame", {
        Parent = inline,
        Position = dim2(0, 1, 0, 1),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(0.5, -2, 1, -2),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.accent
    })

    function cfg.set(value)
        cfg.value = clamp(library:round(value, cfg.intervals), cfg.min, cfg.max)
        fill.Size = dim2((cfg.value - cfg.min) / (cfg.max - cfg.min), -2, 1, -2)
        value_label.Text = tostring(cfg.value) .. cfg.suffix
        flags[cfg.flag] = cfg.value
        cfg.callback(cfg.value)
    end

    function cfg.set_element_visible(bool)
        slider_frame.Visible = bool
    end

    library:connection(uis.InputChanged, function(input)
        if cfg.dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local size_x = (input.Position.X - slider_bg.AbsolutePosition.X) / slider_bg.AbsoluteSize.X
            local value = ((cfg.max - cfg.min) * size_x) + cfg.min
            cfg.set(value)
        end
    end)

    library:connection(uis.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            cfg.dragging = false
        end
    end)

    slider_bg.MouseButton1Down:Connect(function()
        cfg.dragging = true
    end)

    cfg.set(cfg.default)

    config_flags[cfg.flag] = cfg.set
    library.config_flags[cfg.flag] = cfg.set
    library.visible_flags[cfg.flag] = cfg.set_element_visible

    return cfg
end

