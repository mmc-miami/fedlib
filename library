        dropdown_menu.Position = dim2(0, dropdown.AbsolutePosition.X, 0, dropdown.AbsolutePosition.Y + 20)
    end

    dropdown.MouseButton1Click:Connect(function()
        cfg.open = not cfg.open
        cfg.set_visible(cfg.open)
    end)

    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set

    return setmetatable(cfg, {__index = library})
end

-- // KEYBIND CREATION
function library:keybind(options)
    local cfg = {
        name = options.name or "Keybind",
        flag = options.flag or "keybind_" .. math.random(1, 9999),
        key = options.key or nil,
        mode = options.mode or "toggle",
        callback = options.callback or function() end,
        binding = false,
    }

    flags[cfg.flag] = {key = cfg.key, mode = cfg.mode, active = false}

    local keybind_button = self:create("TextButton", {
        Parent = self.right_holder or self.holder,
        Text = "",
        AutoButtonColor = false,
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(0, 24, 0, 14),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.outline,
    })

    local key_text = self:create("TextLabel", {
        Parent = keybind_button,
        FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Regular),
        TextColor3 = themes.preset.text,
        Text = cfg.key and cfg.key.Name or "...",
        Size = dim2(1, 0, 1, 0),
        BackgroundTransparency = 1,
        TextSize = 10,
        BorderSizePixel = 0,
    })

    function cfg.set(key)
        cfg.key = key
        key_text.Text = key.Name or "..."
        flags[cfg.flag].key = key
        cfg.callback(key)
    end

    keybind_button.MouseButton1Down:Connect(function()
        cfg.binding = true
        key_text.Text = "..."
        local connection
        connection = uis.InputBegan:Connect(function(input, gpe)
            if not gpe and cfg.binding then
                cfg.set(input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType)
                cfg.binding = false
                connection:Disconnect()
            end
        end)
    end)

    return setmetatable(cfg, {__index = library})
end

return library
