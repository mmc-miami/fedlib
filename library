        callback = options.callback or function() end,
        placeholder = options.placeholder or "Enter text...",
        default = options.default or "",
    }

    flags[cfg.flag] = cfg.default

    local frame = library:create("Frame", {
        Parent = self and self.holder or nil,
        Name = "textbox_" .. cfg.flag,
        BackgroundTransparency = 1,
        Size = dim2(1, -8, 0, 0),
        BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y
    })

    local label = library:create("TextLabel", {
        Parent = frame,
        Text = cfg.name,
        TextColor3 = themes.preset.text,
        BackgroundTransparency = 1,
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(1, 0, 0, 14),
        BorderSizePixel = 0,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local input = library:create("TextBox", {
        Parent = frame,
        Name = "input",
        Text = cfg.default,
        TextColor3 = themes.preset.text,
        BackgroundColor3 = themes.preset.outline,
        BorderColor3 = rgb(0, 0, 0),
        Position = dim2(0, 0, 0, 16),
        Size = dim2(1, 0, 0, 18),
        BorderSizePixel = 0,
        TextSize = 10,
        PlaceholderText = cfg.placeholder,
    })

    local inline = library:create("Frame", {
        Parent = input,
        Position = dim2(0, 1, 0, 1),
        BorderColor3 = rgb(0, 0, 0),
        Size = dim2(1, -2, 1, -2),
        BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.inline
    })

    function cfg.set(value)
        input.Text = value
        flags[cfg.flag] = value
        cfg.callback(value)
    end

    function cfg.set_element_visible(bool)
        frame.Visible = bool
    end

    input.FocusLost:Connect(function()
        cfg.set(input.Text)
    end)

    return cfg
end

-- ===== CLEANUP =====

function library:cleanup()
    for _, con in ipairs(library.connections) do
        pcall(function() con:Disconnect() end)
    end

    for _, gui in ipairs(library.guis) do
        pcall(function() gui:Destroy() end)
    end

    library.connections = {}
    library.guis = {}
end

return library
